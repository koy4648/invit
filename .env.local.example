# =============================================================================
# 모바일 청첩장 환경 변수 설정 파일
# 이 파일을 복사하여 .env.local 로 저장한 후 실제 값을 입력하세요.
# .env.local 파일은 절대 Git에 커밋하지 마세요!
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase 설정
# https://supabase.com/dashboard → 프로젝트 → Settings → API
# -----------------------------------------------------------------------------

# Supabase 프로젝트 URL (예: https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon (공개) 키 - 클라이언트 사이드에서 사용
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role 키 - 서버 사이드 전용 (절대 클라이언트에 노출 금지)
# API Route에서 RLS를 우회하여 데이터 조작 시 사용
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# Cloudflare R2 설정
# https://dash.cloudflare.com → R2 → Manage R2 API Tokens
# -----------------------------------------------------------------------------

# Cloudflare 계정 ID (대시보드 우측 하단에서 확인)
R2_ACCOUNT_ID=your-cloudflare-account-id

# R2 API 토큰 - Access Key ID
# (R2 → Manage R2 API Tokens → Create API Token → Object Read & Write 권한)
R2_ACCESS_KEY_ID=your-r2-access-key-id

# R2 API 토큰 - Secret Access Key
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# R2 버킷 이름 (R2에서 생성한 버킷 이름)
R2_BUCKET_NAME=wedding-photos

# R2 퍼블릭 URL (버킷에 커스텀 도메인 또는 r2.dev 도메인 설정 시 입력)
# 예: https://pub-xxxxxxxxxxxx.r2.dev 또는 https://photos.yourdomain.com
# 설정하지 않으면 업로드 후 미리보기가 blob URL로 표시됩니다.
R2_PUBLIC_URL=https://pub-your-bucket-id.r2.dev

# =============================================================================
# Supabase guestbook 테이블 생성 SQL (Supabase SQL Editor에서 실행)
# =============================================================================
#
# CREATE TABLE IF NOT EXISTS public.guestbook (
#   id          UUID DEFAULT gen_random_uuid() PRIMARY KEY,
#   name        VARCHAR(20)  NOT NULL CHECK (char_length(name) >= 1),
#   password    VARCHAR(100) NOT NULL CHECK (char_length(password) >= 4),
#   message     TEXT         NOT NULL CHECK (char_length(message) >= 1 AND char_length(message) <= 200),
#   created_at  TIMESTAMPTZ  NOT NULL DEFAULT NOW()
# );
#
# -- Row Level Security 활성화
# ALTER TABLE public.guestbook ENABLE ROW LEVEL SECURITY;
#
# -- 누구나 읽기 가능 (SELECT)
# CREATE POLICY "guestbook_select_policy"
#   ON public.guestbook FOR SELECT
#   USING (true);
#
# -- 누구나 쓰기 가능 (INSERT) - 서비스 특성상 인증 없이 허용
# CREATE POLICY "guestbook_insert_policy"
#   ON public.guestbook FOR INSERT
#   WITH CHECK (true);
#
# -- 인덱스 생성
# CREATE INDEX idx_guestbook_created_at ON public.guestbook (created_at DESC);
#
# =============================================================================
# Cloudflare R2 CORS 설정 (R2 버킷 → Settings → CORS Policy)
# =============================================================================
#
# [
#   {
#     "AllowedOrigins": ["https://your-vercel-domain.vercel.app", "http://localhost:3000"],
#     "AllowedMethods": ["PUT", "GET", "HEAD"],
#     "AllowedHeaders": ["Content-Type", "Content-Length"],
#     "ExposeHeaders": ["ETag"],
#     "MaxAgeSeconds": 3600
#   }
# ]
#
# =============================================================================
